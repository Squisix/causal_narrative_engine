# ============================================================================
# Configuración de Anthropic API (Claude)
# ============================================================================
#
# IMPORTANTE:
# 1. Copia este archivo a .env (sin el .example)
# 2. Reemplaza "tu-api-key-aquí" con tu key real de Anthropic
# 3. NUNCA subas .env a Git (ya está en .gitignore)
#
# Obtener API key:
# https://console.anthropic.com/settings/keys
# ============================================================================

# API Key (REQUERIDO para usar AnthropicAdapter)
ANTHROPIC_API_KEY=sk-ant-api03-tu-api-key-aquí

# Modelo a usar (OPCIONAL - por defecto: claude-3-5-sonnet-20241022)
# Opciones:
#   - claude-3-5-sonnet-20241022  (recomendado: balance calidad/precio)
#   - claude-opus-4               (máxima calidad, más caro)
#   - claude-haiku-3              (rápido y económico)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Máximo de tokens a generar (OPCIONAL - por defecto: 2048)
ANTHROPIC_MAX_TOKENS=2048

# Temperatura de generación 0.0-1.0 (OPCIONAL - por defecto: 0.7)
# Valores más bajos = más determinista
# Valores más altos = más creativo
ANTHROPIC_TEMPERATURE=0.7

# ============================================================================
# Otras configuraciones opcionales
# ============================================================================

# PostgreSQL (para Fase 2)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/cne_db

# Redis (para Fase 4 - cache)
# REDIS_URL=redis://localhost:6379
