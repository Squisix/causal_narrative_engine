# ============================================================================
# Anthropic API (Claude) Configuration
# ============================================================================
#
# IMPORTANT:
# 1. Copy this file to .env (without the .example)
# 2. Replace "your-api-key-here" with your real Anthropic key
# 3. NEVER push .env to Git (it is already in .gitignore)
#
# Get API key:
# https://console.anthropic.com/settings/keys
# ============================================================================

# API Key (REQUIRED to use AnthropicAdapter)
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here

# Model to use (OPTIONAL - default: claude-3-5-sonnet-20241022)
# Options:
#   - claude-3-5-sonnet-20241022  (recommended: quality/price balance)
#   - claude-opus-4               (highest quality, more expensive)
#   - claude-haiku-3              (fast and affordable)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens to generate (OPTIONAL - default: 2048)
ANTHROPIC_MAX_TOKENS=2048

# Generation temperature 0.0-1.0 (OPTIONAL - default: 0.7)
# Lower values = more deterministic
# Higher values = more creative
ANTHROPIC_TEMPERATURE=0.7

# ============================================================================
# Other optional settings
# ============================================================================

# PostgreSQL (for Phase 2)
# DATABASE_URL=postgresql://user:password@localhost:5432/cne_db

# Redis (cache — optional, the system works fine without Redis)
# With Docker Compose: redis://localhost:6379
# Without Docker: install Redis locally or leave commented out
REDIS_URL=redis://localhost:6379

# ============================================================================
# AI Interaction Logging Configuration
# ============================================================================
# Enable/Disable saving all AI prompts and responses to logs/world_<world_id>.jsonl
# Options: true (default), false
ENABLE_AI_LOGGING=true
